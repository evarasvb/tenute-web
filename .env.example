# ============================================================
# TENUTE WEB — Variables de entorno requeridas para producción
# Copiar como .env.local y rellenar con valores reales.
# NUNCA commitear .env.local al repositorio.
# ============================================================

# ── Supabase (obligatorio) ───────────────────────────────
# Obtener en: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — solo server-side (API routes). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Panel de administración ──────────────────────────────
# Contraseña del admin panel (/admin/login)
ADMIN_PASSWORD=cambia_esto_en_produccion

# ── Flow.cl (pagos con tarjeta) ──────────────────────────
# Obtener en: https://www.flow.cl/app/web/misDatos.php
FLOW_API_KEY=
FLOW_SECRET_KEY=
# Sandbox: usar 'true' para pruebas, 'false' o vacío en producción
FLOW_SANDBOX=true

# ── Starken (despacho nacional) ──────────────────────────
# Solicitar a Starken: 600 200 0102
STARKEN_API_KEY=

# ── Email / notificaciones ───────────────────────────────
# Email origen para notificaciones de pedidos (debe estar verificado en tu proveedor SMTP)
EMAIL_FROM=noreply@tenute.cl
# SMTP (usando Resend, SendGrid, SES, etc.)
# Ejemplo con Resend: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# O bien con Nodemailer/SMTP genérico:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=usuario@gmail.com
# SMTP_PASS=contraseña_app

# ── Instagram (scraping de posts, opcional) ──────────────
# Session cookie de Instagram (_sessionid) para el scraper interno.
# Solo necesario si se usa /api/admin/instagram
INSTAGRAM_SESSION_ID=

# ── MercadoPago (actualmente deshabilitado) ──────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── URL base (callbacks, canonicals) ────────────────────
# Se auto-detecta en Vercel. Solo definir si usas dominio propio.
NEXT_PUBLIC_BASE_URL=https://www.tenute.cl

# ── Base de datos directa (migraciones, opcional) ────────
# Formato: postgresql://postgres.{ref}:{password}@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
