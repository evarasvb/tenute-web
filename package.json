{
  "name": "tenute-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --no-cache",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --passWithNoTests"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": ["/node_modules/", "/.next/"],
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", { "tsconfig": { "jsx": "react-jsx" } }]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "mercadopago": "^2.12.0",
    "next": "14.2.5",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "jest": "^29",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29",
    "typescript": "^5"
  }
}
